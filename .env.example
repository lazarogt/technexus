NODE_ENV=development

POSTGRES_DB=technexus
POSTGRES_USER=technexus
POSTGRES_PASSWORD=technexus
POSTGRES_PORT=5433

BACKEND_PORT=4000
FRONTEND_PORT=5173
REDIS_PORT=6380
REDIS_ENABLED=false

JWT_SECRET=technexus-super-secret-jwt
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://frontend:5173
EMAIL_FROM=notifications@technexus.local

CACHE_TTL_PRODUCTS=120
CACHE_TTL_CATEGORIES=300
CACHE_TTL_PROFILE=90
CACHE_TTL_SEARCH=60
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20
DB_MAX_RETRIES=30
DB_RETRY_DELAY_MS=2000
PASSWORD_SALT_ROUNDS=12

TECHNEXUS_ADMIN_EMAIL=admin@example.com
TECHNEXUS_ADMIN_PASSWORD=Admin1234!
TECHNEXUS_SELLER_EMAIL=seller@example.com
TECHNEXUS_SELLER_PASSWORD=Seller1234!
TECHNEXUS_CUSTOMER_EMAIL=customer@example.com
TECHNEXUS_CUSTOMER_PASSWORD=Customer1234!
